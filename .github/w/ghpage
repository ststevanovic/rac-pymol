name: ghpage

on:
  workflow_dispatch:
    inputs:
      scenography:
        description: "Scenography URL or path (e.g. https://… or local/<name>.db)"
        required: false
        default: ""
      scene_id:
        description: "Scene ID to render (e.g. 9ax6)"
        required: true
        default: "9ax6"

# Trigger: manual dispatch from the landing page CTA-button ("Render")
# This is the workflow wired to the ghpage UI's CTA.
# For the full render pipeline see ../workflows/render.yml

defaults:
  run:
    working-directory: rac_pymol

jobs:
  render:
    name: ghpage Render
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Install Conda (miniforge)
        uses: conda-incubator/setup-miniconda@v3
        with:
          miniforge-variant: Mambaforge
          python-version: "3.11"
          activate-environment: pymol-ci

      - name: Install PyMOL open-source + project deps + plotly
        shell: bash -el {0}
        run: |
          mamba install -y -c conda-forge pymol-open-source
          pip install -e ".[dev]"
          pip install plotly

      - name: Install headless display libs
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y --no-install-recommends \
            libgl1-mesa-dri libgl1-mesa-glx libosmesa6 xvfb zip

      - name: Resolve scenography DB (curl-wrapper)
        shell: bash -el {0}
        env:
          SCENOGRAPHY_INPUT: ${{ github.event.inputs.scenography }}
        run: bash .github/scripts/curl_wrapper.sh "${SCENOGRAPHY_INPUT}"

      - name: Prepare enzyme reference scene (custom scenography only)
        if: ${{ github.event.inputs.scenography != '' }}
        shell: bash -el {0}
        env:
          DISPLAY: ":99"
          LIBGL_ALWAYS_SOFTWARE: "1"
          MESA_GL_VERSION_OVERRIDE: "3.3"
        run: |
          Xvfb :99 -screen 0 1280x1024x24 &
          sleep 2
          conda run -n pymol-ci python pymol-workshop/enzyme.py

      - name: "MAIN: run batch pipeline"
        shell: bash -el {0}
        env:
          DISPLAY: ":99"
          LIBGL_ALWAYS_SOFTWARE: "1"
          MESA_GL_VERSION_OVERRIDE: "3.3"
          BATCH_N_SUBJECTS: "2"
        run: |
          Xvfb :99 -screen 0 1280x1024x24 &
          sleep 2
          conda run -n pymol-ci python pymol-workshop/batch.py "${{ github.event.inputs.scene_id }}" 2>&1 | tee .rendering/run.log

      - name: Package rendered output
        shell: bash -el {0}
        run: python .github/scripts/download_zip.py

      - name: Upload HTML slide deck
        uses: actions/upload-artifact@v4
        with:
          name: slide-deck-html
          path: rac_pymol/.rendering/random/latest.html
          retention-days: 14

      - name: Upload zipped slide deck
        uses: actions/upload-artifact@v4
        with:
          name: slide-deck-zip
          path: rac_pymol/.rendering/random/latest.zip
          retention-days: 14

      - name: Upload terminal log
        uses: actions/upload-artifact@v4
        with:
          name: run-log
          path: rac_pymol/.rendering/run.log
          retention-days: 14

      - name: Upload full render artefacts on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: render-artefacts-failure
          path: rac_pymol/.rendering/
          retention-days: 7
